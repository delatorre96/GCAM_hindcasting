error_summary_by_criteria <- function(df_all_errors, criteria){
df_all_errors_by_criteria <- df_all_errors %>%
group_by(criteria) %>%
summarise(
RMSE = sqrt(mean(error^2)),
MAE = mean(abs(error)),
MaxAE = max(abs(error)),
MeanRef = mean(abs(value_ref)),
NRMSE = if_else(
MeanRef == 0,
RMSE,
RMSE / MeanRef
),
NMAE = if_else(
MeanRef == 0,
MAE,
MAE / MeanRef
),
NMaxAE = if_else(
MeanRef == 0,
MaxAE,
MaxAE / MeanRef
),
.groups = "drop"
) %>%
arrange(desc(NRMSE)) %>%
mutate(NRMSE_cumsum =  cumsum(NRMSE)/sum(NRMSE)) %>%
select(-RMSE, -MAE, - MaxAE, -MeanRef)
df_all_errors_by_criteria
}
