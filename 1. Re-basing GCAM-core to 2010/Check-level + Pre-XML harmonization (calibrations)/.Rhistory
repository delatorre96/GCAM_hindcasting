na_summary_df <- function(df, df_name = NULL) {
na_counts <- sapply(df, function(x) sum(is.na(x)))
data.frame(
df = df_name,
column = names(na_counts),
na_count = as.integer(na_counts),
row.names = NULL
)
}
na_summary_chunk <- function(chunk) {
res <- lapply(names(chunk), function(df_i) {
na_summary_df(chunk[[df_i]], df_i)
})
do.call(rbind, res)
}
