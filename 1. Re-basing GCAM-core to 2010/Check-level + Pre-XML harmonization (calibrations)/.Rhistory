detect_keys<- function(df1, df2) {
common_cols <- intersect(names(df1), names(df2))
# excluir calibración explícita
candidates <- common_cols[
!grepl("^cal|^base\\.", common_cols)
]
# quedarse solo con variables tipo string/factor
candidates <- candidates[
sapply(df1[candidates], function(x) {
is.character(x) || is.factor(x)
})
]
candidates
}
