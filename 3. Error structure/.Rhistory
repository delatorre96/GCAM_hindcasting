error_summary_by_criteria <- function(df_all_errors, criteria) {
df_all_errors %>%
group_by(.data[[criteria]]) %>%
summarise(
RMSE = sqrt(mean(error^2, na.rm = TRUE)),
MAE = mean(abs(error), na.rm = TRUE),
MaxAE = max(abs(error), na.rm = TRUE),
MeanRef = mean(abs(value_ref), na.rm = TRUE),
NRMSE = if_else(
MeanRef == 0,
RMSE,
RMSE / MeanRef
),
NMAE = if_else(
MeanRef == 0,
MAE,
MAE / MeanRef
),
NMaxAE = if_else(
MeanRef == 0,
MaxAE,
MaxAE / MeanRef
),
.groups = "drop"
) %>%
arrange(desc(NRMSE)) %>%
mutate(NRMSE_cumsum = cumsum(NRMSE) / sum(NRMSE)) %>%
select(-RMSE, -MAE, -MaxAE, -MeanRef)
}
