coefs <- summary(modelo)$coefficients
sig <- rownames(coefs)[coefs[, "Pr(>|t|)"] < 0.05]
tech_sig <- sub("^technology", "", sig)
tech_sig <- c("biomass to H2", tech_sig)
datos2 <- subset(
hydrogen_costs_RMSE,
technology %in% tech_sig
)
modelo2 <- lm(error_abs ~ technology, data = datos2)
summary(modelo2)
