detect_keys <- function(df1, df2) {
common_cols <- intersect(names(df1), names(df2))
# excluir columnas claramente no identificadoras
candidates <- common_cols[!grepl("^cal|^base\\.", common_cols)]
# heurística: quitar columnas numéricas continuas (malas keys)
candidates <- candidates[
sapply(df1[candidates], function(x) !is.numeric(x) || length(unique(x)) < 50)
]
candidates
}
